rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- HELPERS ----------------
    function isSignedIn() {
      return request.auth != null;
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isMemberOfRoom(roomId) {
      return isSignedIn() &&
        request.auth.uid in roomDoc(roomId).data.members;
    }

    function isCreatorOfRoom(roomId) {
      return isSignedIn() &&
        request.auth.uid == roomDoc(roomId).data.createdBy;
    }

    function isFinalMemberOfRoom(roomId) {
      return isSignedIn() &&
        request.auth.uid in roomDoc(roomId).data.members &&
        roomDoc(roomId).data.members.size() <= 1;
    }

    // Expense ownership helper (legacy-friendly)
    function isExpenseOwner() {
      return isSignedIn() && (
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.uid ||
        request.auth.uid == resource.data.paidBy ||
        request.auth.uid == resource.data.addedBy ||
        request.auth.uid == resource.data.authorId
      );
    }

    // ---------------- WEBSITE STATS ----------------
    match /appStats/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // ---------------- CERTIFICATES ----------------
    match /certificates/{certificateId} {
      allow get: if true;
      allow list: if false; // Prevent mass scraping
      allow write: if false; // Add/edit via Firebase Console only
    }

    // ---------------- USERS ----------------
    match /users/{userId} {
      // Allow fetching a specific user profile (needed for room members / UI)
      // Disallow listing all users to prevent enumeration
      allow get: if isSignedIn();
      allow list: if false; // No endpoint should ever need to list all users

      // User can manage only own profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /tokens/{tokenId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /personal_expenses/{expenseId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /udhar_transactions/{udharId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /fixed_bills/{billId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ---------------- COLLECTION GROUP: TASK INSTANCES ----------------
    match /{path=**}/taskInstances/{instanceId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.assignedTo;
    }

    // ---------------- ROOMS ----------------
    match /rooms/{roomId} {

      // Create room
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdBy &&
        request.auth.uid in request.resource.data.members;

      // Allow direct room fetch (for join flow / invite code / preview)
      allow get: if isSignedIn();

      // Prevent any user from enumerating all rooms in the system
      allow list: if false; // App queries rooms by member field, never lists all

      // ---------------- ROOM UPDATE ----------------
      allow update: if isSignedIn() && (

        // Existing room members can update room
        (
          request.auth.uid in resource.data.members &&
          request.resource.data.createdBy == resource.data.createdBy
        )

        ||

        // NEW USER JOIN ROOM
        (
          !(request.auth.uid in resource.data.members) &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.members.size() >= resource.data.members.size() + 1 &&
          request.resource.data.createdBy == resource.data.createdBy
        )
      );

      // Delete room
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdBy ||
        (
          request.auth.uid in resource.data.members &&
          resource.data.members.size() <= 1
        )
      );

      // ---------------- EXPENSES ----------------
      match /expenses/{expenseId} {
        allow create: if isMemberOfRoom(roomId);
        allow read: if isMemberOfRoom(roomId);

        allow update, delete: if isMemberOfRoom(roomId) && (
          isExpenseOwner() || isCreatorOfRoom(roomId)
        );
      }

      // ---------------- TASK CATEGORIES ----------------
      match /task_categories/{categoryId} {
        allow create, read, update, delete: if isMemberOfRoom(roomId);
      }

      // ---------------- TASKS ----------------
      match /tasks/{taskId} {
        allow create, read, update, delete: if isMemberOfRoom(roomId);
      }

      // ---------------- CHATS ----------------
      match /chats/{messageId} {
        allow read, create: if isMemberOfRoom(roomId);

        allow update: if isMemberOfRoom(roomId) && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollOptions']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hiddenBy']) ||
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.uid ||
          request.auth.uid == resource.data.sentBy ||
          request.auth.uid == resource.data.authorId
        );

        allow delete: if isMemberOfRoom(roomId) && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.uid ||
          request.auth.uid == resource.data.sentBy ||
          request.auth.uid == resource.data.authorId ||
          isCreatorOfRoom(roomId)
        );
      }

      // ---------------- PAYMENTS ----------------
      match /payments/{paymentId} {
        allow create, read: if isMemberOfRoom(roomId);

        allow delete: if isMemberOfRoom(roomId) && (
          request.auth.uid == resource.data.createdBy ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.uid ||
          request.auth.uid == resource.data.authorId ||
          isCreatorOfRoom(roomId)
        );

        allow update: if false;
      }

      // ---------------- MEDIA ----------------
      match /media/{mediaId} {
        allow read, create: if isMemberOfRoom(roomId);
        allow delete: if isCreatorOfRoom(roomId);
        allow update: if false;
      }

      // ---------------- POINT TRANSACTIONS ----------------
      match /pointTransactions/{transactionId} {
        allow read, create: if isMemberOfRoom(roomId);
        allow update, delete: if false;
      }

      // ---------------- TASK INSTANCES ----------------
      match /taskInstances/{instanceId} {
        allow create: if isMemberOfRoom(roomId);

        allow read: if isMemberOfRoom(roomId) || (
          isSignedIn() && request.auth.uid == resource.data.assignedTo
        );

        allow update, delete: if isMemberOfRoom(roomId);
      }

      // ---------------- AUDIT LOG ----------------
      match /auditLog/{logId} {
        allow read, create: if isMemberOfRoom(roomId);
        allow update: if false;
        allow delete: if isCreatorOfRoom(roomId) || isFinalMemberOfRoom(roomId);
      }

      // ---------------- ROOM NOTIFICATIONS ----------------
      match /notifications/{notificationId} {
        allow read, create: if isMemberOfRoom(roomId);
        allow update: if false;
        allow delete: if isCreatorOfRoom(roomId) || isFinalMemberOfRoom(roomId);
      }
    }

    // ---------------- TOP LEVEL NOTIFICATIONS ----------------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;

      allow create: if isSignedIn() &&
        request.resource.data.userId is string &&
        request.resource.data.roomId is string &&
        request.resource.data.type is string &&
        request.resource.data.title is string &&
        request.resource.data.message is string &&
        request.resource.data.isRead == false &&
        request.resource.data.createdAt is timestamp;

      allow update: if isSignedIn() &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.roomId == resource.data.roomId &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.message == resource.data.message;

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ---------------- BUG REPORTS ----------------
    match /bug_reports/{reportId} {
      allow create: if isSignedIn() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 5 &&
        request.resource.data.contact is string &&
        request.resource.data.contact.size() > 0 &&
        request.resource.data.userId is string &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.attachments is list &&
        request.resource.data.createdAt is timestamp;

      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;

      allow update, delete: if false;
    }
  }
}